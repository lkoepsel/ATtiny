#!/bin/sh
# node-confined — run Node confined to the current project directory.
#
# Purpose: Sublime's Debugger package launches the Native Debug (code-debug)
# adapter with Node. Point the Debugger "node path" setting at this wrapper so
# the adapter — and the avr-gdb it spawns — run inside a bubblewrap sandbox that
# cannot read $HOME secrets (~/.ssh, dotfiles, browser data) or persist outside
# the project. See docs/dap_sublime_debug.md ("Node.js: install minimally &
# sandbox").
#
# Requires: bubblewrap (/usr/bin/bwrap), already present on this box.
#
# Notes:
#   --unshare-all --share-net  isolates PID/IPC/etc but KEEPS networking on
#       purpose, because avr-gdb still needs loopback to reach Bloom's gdb
#       server on 127.0.0.1:1442. Fully unsharing the net namespace would bring
#       loopback down and break the connection.
#   $HOME is intentionally NOT bound, so ~/.gdbinit will not load inside the
#       sandbox — under Native Debug the .sublime-project config drives gdb.

exec bwrap \
  --ro-bind /usr /usr \
  --symlink usr/lib /lib \
  --symlink usr/lib /lib64 \
  --symlink usr/bin /bin \
  --ro-bind /etc /etc \
  --proc /proc \
  --dev /dev \
  --tmpfs /tmp \
  --bind "$PWD" "$PWD" \
  --chdir "$PWD" \
  --unshare-all --share-net \
  --die-with-parent \
  /usr/bin/node "$@"
